{
import sys
}
let DIGIT = [0-9]
let IDSTART = [a-zA-Z_]
let IDREST = [a-zA-Z0-9_]

rule gettoken =
[ \t]+ { pass }    # espacios -> ignorar
[\n] { print(('SDL','\\n')) }
{DIGIT}+ { print(('INT', int(lxm)) ) }
{IDSTART}{IDREST}* { print(('ID', lxm)) }
'+' { print(('SUMA', '+')) }
'-' { print(('RESTA', '-')) }
'(' { print(('PARENI','(')) }
')' { print(('PAREND',')')) }
eof { raise('Fin de buffer') }